{
  "name": "docs",
  "version": "0.1.8",
  "description": "Documentation site (@dreamlake/dockit shell + MDX pages)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && ([ -f dist/client/index.html ] || vike prerender) && node scripts/gen-llms.mjs && pagefind --site dist/client",
    "preview": "vite preview",
    "gen:llms": "node scripts/gen-llms.mjs",
    "check:llms": "node scripts/gen-llms.mjs --check"
  },
  "dependencies": {
    "@dreamlake/dockit": "^0.2.6",
    "@dreamlake/uikit": "workspace:*",
    "@mdx-js/react": "latest",
    "lucide-react": "^1.21.0",
    "react": "latest",
    "react-dom": "latest",
    "vike": "^0.4.260",
    "vike-react": "^0.5.0"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "pagefind": "^1.5.2",
    "tailwindcss": "^4.3.2",
    "typescript": "^5.7.0",
    "vite": "^7.3.6"
  }
}
