{
  "name": "docs",
  "version": "0.1.7",
  "description": "Documentation site (Vike + MDX)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/gen-llms.mjs && pagefind --site dist/client",
    "preview": "vite preview",
    "gen:llms": "node scripts/gen-llms.mjs",
    "check:llms": "node scripts/gen-llms.mjs --check"
  },
  "dependencies": {
    "@dreamlake/uikit": "workspace:*",
    "@mdx-js/react": "latest",
    "lucide-react": "^1.21.0",
    "@mdx-js/rollup": "^3.1.1",
    "@shikijs/rehype": "^1.24.0",
    "react": "latest",
    "react-dom": "latest",
    "rehype-slug": "^6.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-mdx-frontmatter": "^5.2.0",
    "shiki": "^1.24.0",
    "tailwindcss": "^4.0.0",
    "vike": "^0.4.210",
    "vike-react": "^0.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.0",
    "pagefind": "^1.5.2",
    "vite": "^7.0.0"
  }
