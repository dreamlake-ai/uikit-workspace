{
  "name": "uikit-workspace",
  "version": "0.1.3",
  "description": "@dreamlake/uikit workspace — UI primitives + Vike/MDX doc site",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter docs dev",
    "build": "pnpm --filter @dreamlake/uikit build && pnpm --filter docs build",
    "preview": "pnpm --filter docs preview",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "set-version": "node scripts/set-version.mjs",
    "version-branch": "node scripts/push-version-branch.mjs",
    "prod": "pnpm version-branch && git push -f origin HEAD:netlify-production",
    "staging": "git push -f origin HEAD:netlify-staging"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "^5.7.0"
  },
  "packageManager": "pnpm@10.33.0"
}
